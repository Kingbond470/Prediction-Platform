# Copy this to .env.local and fill in your Supabase credentials
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-key-here
NEXT_PUBLIC_APP_URL=http://localhost:3000
ODDS_API_KEY=your-odds-api-key-here

# Admin panel secret — set a long random string (openssl rand -hex 32)
# Required to access /admin and score match results. Never commit the real value.
ADMIN_SECRET=change-me-use-openssl-rand-hex-32

# PostHog Analytics — get free key at https://app.posthog.com
# Leave empty to disable PostHog (Vercel Analytics still works without this)
NEXT_PUBLIC_POSTHOG_KEY=phc_your-posthog-key-here
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Web Push (VAPID) — generate once with: node -e "require('web-push').generateVAPIDKeys()"
# NEXT_PUBLIC_VAPID_PUBLIC_KEY goes to the browser; VAPID_PRIVATE_KEY stays server-only
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# CricAPI — live scores + automatic result detection
# Sign up at https://cricapi.com/ (free tier: 100 requests/day)
CRICAPI_KEY=your-cricapi-key

# Vercel Cron secret — protects /api/cric-sync from public calls
# Generate: openssl rand -hex 32
CRON_SECRET=change-me-use-openssl-rand-hex-32
